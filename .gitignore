# ==========================================================
# === ML Model Artifacts (EXCLUDED FROM REPO)
# ==========================================================
# All model weights, checkpoints, and binary serialisations
# are stored in the separate Hugging Face model repository:
#   https://huggingface.co/Hariom9951/AI-Medical-Diagnosis-Models
#
# The ModelDownloader service (src/utils/downloader.py) fetches
# and caches them locally at first startup automatically.
# Do NOT commit any model binary files to this repository.
# ==========================================================

# PyTorch model weights
*.pt
*.pth
*.onnx
*.bin

# Scikit-learn serialisations
*.pkl
*.joblib

# TensorFlow / ONNX
*.pb
*.h5
*.hdf5

# Training run artifacts
models/*
!models/.gitkeep

# artifacts/ — keep folder stubs, exclude all binary content
artifacts/*
!artifacts/.gitkeep

# Explicitly allow non-binary metadata / placeholder files
# (but never the actual weight files)
!artifacts/checkpoints/
!artifacts/checkpoints_nlp/

# === Streamlit ===
.streamlit/config.toml
.streamlit/secrets.toml

# === DVC (Data Version Control) ===
.dvc/cache/
.dvc/tmp/
.dvc/config.local

# === MLflow ===
mlruns/
mlflow.db

# === Docker ===
.docker/
docker-compose.override.yml

# === Data ===
data/*
!data/processed/
data/processed/*
!data/processed/disease_mapping.json
!data/processed/disease_mapping_41.json
