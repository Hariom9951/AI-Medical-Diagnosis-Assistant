# ==========================================================
# AI Medical Diagnosis Assistant — Environment Configuration
# ==========================================================
# Copy this file to .env and fill in the required values.
# NEVER commit your .env file to version control.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
# ==========================================================

# ----------------------------------------------------------
# Hugging Face Configuration
# ----------------------------------------------------------

# HF API Token — required to download model checkpoints from
# the model repository on first startup.
# Create a read-only token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Model repository ID containing the fine-tuned checkpoints.
# Default: Hariom9951/AI-Medical-Diagnosis-Models
# Only change this if you are hosting your own model copy.
HF_MODEL_REPO_ID=Hariom9951/AI-Medical-Diagnosis-Models

# ----------------------------------------------------------
# Optional: Offline Mode
# ----------------------------------------------------------
# Set to "1" to prevent transformers from downloading BioBERT
# base weights from HuggingFace (use locally cached version).
# The ModelDownloader for fine-tuned weights is unaffected.
# TRANSFORMERS_OFFLINE=1
# HF_DATASETS_OFFLINE=1

# ----------------------------------------------------------
# Optional: MLflow Tracking
# ----------------------------------------------------------
# MLFLOW_TRACKING_URI=http://localhost:5000
# DAGSHUB_USER_TOKEN=your_dagshub_token_here

# ----------------------------------------------------------
# Optional: Kaggle (for dataset download)
# ----------------------------------------------------------
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key
